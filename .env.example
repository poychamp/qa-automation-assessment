# Optional overrides. Copy this file to .env to use it; the suite runs fine
# without one, since the defaults are the published demo credentials for the
# public sandboxes. In a real project secrets would be injected from CI
# secret storage, never committed.
BOOKER_USER=
BOOKER_PASS=
SAUCE_USER=
SAUCE_PASS=

# Milliseconds of delay per browser action, for watchable headed demo runs.
# Off (0) by default. Example: SLOWMO=600 with --headed.
SLOWMO=
