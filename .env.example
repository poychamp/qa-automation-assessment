# Optional overrides. The defaults in the test code are the published demo
# credentials for the public sandboxes, so no .env file is needed to run the suite.
# In a real project these would be injected from CI secret storage, never committed.
BOOKER_USER=
BOOKER_PASS=
SAUCE_USER=
SAUCE_PASS=

# Milliseconds of delay per browser action, for watchable headed demo runs.
# Off (0) by default. Example: SLOWMO=600 with --headed.
SLOWMO=
